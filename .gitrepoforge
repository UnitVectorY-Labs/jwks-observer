name: jwks-observer
default_branch: main
config:
  description: "Observes and records changes to public OIDC metadata and JWKS for services listed in the [jwks-catalog](https://github.com/UnitVectorY-Labs/jwks-catalog)."
  license: MIT
  language: go
  release: release-go
  justfile: true
  codecov:
    enabled: false
  clip4llm:
    exclude:
      - data
  repver:
    goversion:
      paths:
        - .github/workflows/jwks-observer-run.yml
